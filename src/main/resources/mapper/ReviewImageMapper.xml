<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.nakshi.rohitour.repository.review.ReviewImageMapper">

    <resultMap id="ImageMap" type="com.nakshi.rohitour.dto.ReviewImageDto">
        <id     property="id"         column="id"/>
        <result property="reviewId"   column="review_id"/>
        <result property="imagePath"  column="image_path"/>
        <result property="sortOrder"  column="sort_order"/>
    </resultMap>

    <select id="findByReviewId" resultMap="ImageMap">
        SELECT id, review_id, image_path, sort_order
        FROM review_images
        WHERE review_id = #{reviewId}
        ORDER BY sort_order ASC
    </select>

    <select id="findById" resultMap="ImageMap">
        SELECT id, review_id, image_path, sort_order
        FROM review_images
        WHERE id = #{id}
    </select>

    <select id="countByReviewId" resultType="int">
        SELECT COUNT(*) FROM review_images WHERE review_id = #{reviewId}
    </select>

    <insert id="insert" parameterType="com.nakshi.rohitour.dto.ReviewImageDto"
            useGeneratedKeys="true" keyProperty="id" keyColumn="id">
        INSERT INTO review_images (review_id, image_path, sort_order, created_at)
        VALUES (#{reviewId}, #{imagePath}, #{sortOrder}, NOW())
    </insert>

    <delete id="delete">
        DELETE FROM review_images WHERE id = #{id}
    </delete>

    <delete id="deleteByReviewId">
        DELETE FROM review_images WHERE review_id = #{reviewId}
    </delete>

</mapper>
