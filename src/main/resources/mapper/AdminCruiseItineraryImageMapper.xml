<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.nakshi.rohitour.repository.admin.AdminCruiseItineraryImageMapper">

    <resultMap id="ImageMap" type="com.nakshi.rohitour.dto.CruiseItineraryImageDto">
        <id     property="id"            column="id"/>
        <result property="itineraryId"   column="itinerary_id"/>
        <result property="productId"     column="product_id"/>
        <result property="imagePath"     column="image_path"/>
        <result property="imageType"     column="image_type"/>
        <result property="sortOrder"     column="sort_order"/>
        <result property="createdAt"     column="created_at"/>
    </resultMap>

    <select id="findByItineraryId" resultMap="ImageMap">
        SELECT id, itinerary_id, product_id, image_path, image_type, sort_order, created_at
        FROM itinerary_images
        WHERE itinerary_id = #{itineraryId}
        ORDER BY image_type ASC, sort_order ASC
    </select>

    <select id="findById" resultMap="ImageMap">
        SELECT id, itinerary_id, product_id, image_path, image_type, sort_order, created_at
        FROM itinerary_images
        WHERE id = #{id}
    </select>

    <insert id="insert" parameterType="com.nakshi.rohitour.dto.CruiseItineraryImageDto"
            useGeneratedKeys="true" keyProperty="id" keyColumn="id">
        INSERT INTO itinerary_images (itinerary_id, product_id, image_path, image_type, sort_order, created_at)
        VALUES (#{itineraryId}, #{productId}, #{imagePath}, #{imageType}, #{sortOrder}, NOW())
    </insert>

    <delete id="delete">
        DELETE FROM itinerary_images WHERE id = #{id}
    </delete>

    <delete id="deleteByItineraryId">
        DELETE FROM itinerary_images WHERE itinerary_id = #{itineraryId}
    </delete>

</mapper>
